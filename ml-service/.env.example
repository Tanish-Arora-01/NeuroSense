# ──────────────────────────────────────────────
# NeuroSense ML Service — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# ─── Server ───
ML_SERVICE_PORT=8001
DEBUG=true

# ─── Model ───
MODEL_PATH=./trained_models/dementia_model.pkl

# ─── CORS (Node.js backend origin) ───
ALLOWED_ORIGINS=http://localhost:5000,http://localhost:5173

# ─── Secret key (for any future JWT/token validation) ───
SECRET_KEY=change-me-to-a-real-secret

